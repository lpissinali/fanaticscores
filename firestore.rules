rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // matchdays/{date} — public read, server-only write
    match /matchdays/{date} {
      allow read: if true;
      allow write: if false;  // only Cloud Functions (admin SDK) may write
    }

    // afCache/{key} — shared api-football response cache (see lib/serverApi/sharedCache.ts).
    // Server-only in both directions; the Next.js backend reads/writes via the
    // Admin SDK, which bypasses these rules entirely. No client access needed.
    match /afCache/{key} {
      allow read: if false;
      allow write: if false;
    }

    // rateLimits/{key} — per-IP request counters (see lib/serverApi/rateLimit.ts).
    // Server-only in both directions; the Next.js backend reads/writes via the
    // Admin SDK, which bypasses these rules entirely. No client access needed.
    match /rateLimits/{key} {
      allow read: if false;
      allow write: if false;
    }

    // afDaily/{date} — fleet-wide daily upstream-call budget counters
    // (see lib/serverApi/dailyBudget.ts). Server-only, same as the above.
    match /afDaily/{date} {
      allow read: if false;
      allow write: if false;
    }
  }
}
