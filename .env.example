# ============================================================
# Fanatic Scores — Environment variables
# Copy to .env.local and fill in values (never commit .env.local)
# ============================================================

# football-data.org API key (used by Cloud Functions only — not needed client-side)
# VITE_FD_API_KEY=your_key_here   # legacy local-dev fallback only

# Firebase client config — get from Firebase Console > Project Settings > Your apps
# Required for Firestore real-time updates (production mode)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
