# ============================================================
# Fanatic Scores — Environment variables
# Copy to .env.local and fill in values (never commit .env.local)
# ============================================================

# football-data.org API key
# Get yours at https://www.football-data.org/client/register
VITE_FOOTBALL_DATA_API_KEY=your_api_key_here
VITE_FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4

# Firebase (auto-populated by firebase init, or copy from Firebase Console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
